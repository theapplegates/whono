{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {},
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "archive": {
      "default": true,
      "type": "boolean"
    },
    "publishedAt": {},
    "updatedAt": {},
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "cover": {
      "type": "string"
    },
    "badge": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}