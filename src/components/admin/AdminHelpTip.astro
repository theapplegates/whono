---
import AdminIcon from './AdminIcon.astro';

interface Props {
  id: string;
  label: string;
  text: string;
}

const { id, label, text } = Astro.props;
---

<span class="admin-help-tip">
  <button class="admin-help-tip__trigger" type="button" aria-label={label} aria-describedby={id}>
    <AdminIcon name="info" size={13} strokeWidth={2} />
  </button>
  <span id={id} class="admin-help-tip__bubble" role="tooltip">{text}</span>
</span>
